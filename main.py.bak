import os
from datetime import datetime
from dotenv import load_dotenv # 👈 [핵심] 파이썬에게 이 도구를 쓰겠다고 미리 알려주는 줄입니다!
from langchain_google_genai import ChatGoogleGenerativeAI
from crewai import Agent, Task, Crew
from crewai_tools import FileWriterTool

# 1. API 키 및 두뇌 세팅
load_dotenv() # 👈 [추가] .env 파일(금고)을 엽니다.
gemini_llm = ChatGoogleGenerativeAI(model="gemini-2.0-flash")

# 2. 💡 아이디어를 터미널에서 채팅처럼 직접 입력받기 (질문자님 요청 기능 1)
print("==================================================")
print("🤖 AI 개발 팀이 대기 중입니다!")
my_idea = input("💡 만들고 싶은 프로그램 아이디어를 자유롭게 적어주세요:\n👉 ")
print("==================================================")

# 3. 💡 프로젝트 폴더 자동 생성 (파일이 섞이지 않게 시간별로 새 폴더를 만듭니다)
current_time = datetime.now().strftime("%Y%m%d_%H%M%S")
project_folder = f"my_project_{current_time}"
os.makedirs(project_folder, exist_ok=True) # 폴더 생성

# 파일 쓰기 도구 장착 준비
file_writer_tool = FileWriterTool()

# 4. 에이전트 생성 (역할을 더 고도화했습니다)
planner = Agent(
    role="시스템 아키텍트 및 기획자",
    goal="아이디어를 바탕으로 모듈화(다중 파일)된 완벽한 기획서 및 구조 설계",
    backstory="너는 실리콘밸리 10년 차 소프트웨어 아키텍트야. 코드를 한 파일에 다 몰아넣는 걸 끔찍하게 싫어해. 역할에 따라 여러 파일(예: main.py, logic.py, ui.py 등)로 깔끔하게 나누도록 기획하는 것을 최우선으로 생각해.",
    llm=gemini_llm,
    verbose=True
)

developer = Agent(
    role="파이썬 수석 개발자",
    goal="기획서를 바탕으로 에러 없이 실행 가능한 여러 개의 파이썬 파일들을 물리적으로 직접 생성",
    backstory="너는 꼼꼼한 성격을 가진 천재 파이썬 개발자야. 설계도에 따라 도구(FileWriteTool)를 사용해서 지정된 폴더에 각각의 파이썬 파일들을 실제로 만들어내. 코드는 유지보수가 쉽게 모듈화되어야 해.",
    llm=gemini_llm,
    tools=[file_writer_tool], # 👈 [핵심] 개발자에게 파일 생성 도구를 쥐여줍니다!
    verbose=True
)

# 5. 작업(Task) 지시서 작성
plan_task = Task(
    description=f"다음 사용자의 아이디어를 분석해서 상세한 기능 요구사항과 '파일 구조도(어떤 파일들이 필요한지)'를 기획해: {my_idea}",
    expected_output="마크다운 형식의 상세 기획서와 쪼개진 프로젝트 파일 구조도",
    agent=planner
)

code_task = Task(
    description=f"기획자가 설계한 구조를 바탕으로 완벽하게 동작하는 파이썬 코드를 작성해. 반드시 제공된 FileWriteTool을 사용해서 '{project_folder}' 폴더 안에 여러 개의 .py 파일들을 직접 생성해줘. (예시: {project_folder}/main.py, {project_folder}/game_logic.py 등). 모든 파일이 생성되면 작동 방법과 함께 완료를 보고해.",
    expected_output=f"'{project_folder}' 폴더 안에 실제 생성된 파이썬 파일들의 전체 목록과 실행 방법 설명",
    agent=developer
)

# 6. AI 팀(Crew) 결성 및 업무 시작!
my_crew = Crew(
    agents=[planner, developer],
    tasks=[plan_task, code_task],
    verbose=True
)

print(f"\n🚀 기획자와 개발자가 작업을 시작합니다! (모든 파일은 '{project_folder}' 폴더에 자동 저장됩니다...)")
result = my_crew.kickoff()

print("\n==================================================")
print(f"✅ 최종 결과물 완료! 좌측 파일 목록에서 '{project_folder}' 폴더를 열어보세요!")
print("==================================================")